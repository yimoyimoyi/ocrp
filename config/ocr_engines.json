{
  "engines": {
    "paddleocr": {
      "type": "local",
      "enabled": true,
      "config": {
        "lang": "ch",
        "use_angle_cls": true,
        "use_gpu": false,
        "show_log": false,
        "fast_mode": true,
        "rec_batch_num": 6
      }
    },
    "openai_vision": {
      "type": "api",
      "enabled": true,
      "config": {
        "api_key": "sk-xxx",
        "base_url": "https://api.openai.com/v1",
        "model": "gpt-4o",
        "prompt_template": "请识别图片中的文字，只返回文字内容",
        "timeout": 30,
        "retry": 2
      }
    },
    "ollama_vision": {
      "type": "api",
      "enabled": true,
      "config": {
        "base_url": "http://localhost:11434",
        "model": "llama3.2-vision:11b",
        "prompt_template": "请识别图片中的文字，只返回文字内容",
        "timeout": 60,
        "retry": 2
      }
    },
    "llamacpp": {
      "type": "api",
      "enabled": true,
      "config": {
        "base_url": "http://127.0.0.1:8080",
        "api_key": "not-needed",
        "model": "",
        "prompt_template": "请识别图片中的文字，只返回文字内容",
        "timeout": 60,
        "retry": 2
      }
    }
  },
  "default_engine": "llamacpp"
}
