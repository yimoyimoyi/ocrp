# =============================================================================
# Python 生成文件
# =============================================================================
__pycache__/
*.py[cod]
*.pyo
*.egg
*.egg-info/
*.egg-info

# =============================================================================
# 虚拟环境
# =============================================================================
.venv/
venv/
env/
.python-version

# =============================================================================
# 构建产物
# =============================================================================
build/
dist/
wheels/
*.whl
*.tar.gz

# =============================================================================
# 包管理器
# =============================================================================
uv.lock

# =============================================================================
# NVIDIA CUDA/cuDNN DLL（由 pip 包 nvidia-* 管理，不再捆绑到仓库）
# =============================================================================
core/cuda12/
core/cudnn8/

# =============================================================================
# FFmpeg 捆绑二进制（由 setup.bat 自动下载）
# =============================================================================
core/ffmpeg.exe
core/ffprobe.exe
core/ffplay.exe

# =============================================================================
# ASR 模型文件（过大，由用户自行下载到 models/asr/）
# =============================================================================
models/asr/*.bin
models/asr/**/*.bin
models/asr/*.json
models/asr/**/*.json
models/asr/*.txt
models/asr/**/*.txt
models/asr/.locks/
models/asr/CACHEDIR.TAG

# ── 用户放置 cuDNN 8 DLL（large binary）──
models/asr/lib/

# =============================================================================
# 输出目录
# =============================================================================
output/

# =============================================================================
# IDE / 编辑器
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# 临时文件
# =============================================================================
*.log
*.tmp
*.temp
orcp_asr_*.wav         # ASR 临时音频
ASR_ISSUES_ANALYSIS.md # 一次性分析报告

# =============================================================================
# 用户配置（包含本地路径、API密钥、窗口状态，不提交）
# 首次运行自动从默认模板生成
# =============================================================================
config/settings.json
config/ocr_engines.json
config/asr_engines.json
config/ai_correction.json
config/api_presets.json
config/prompt_templates.json
config/filters.json
